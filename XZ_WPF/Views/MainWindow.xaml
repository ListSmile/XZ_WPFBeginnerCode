<Window x:Class="XZ_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XZ_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" WindowStyle="None" AllowsTransparency="True" Background="{x:Null}">

    <Border CornerRadius="15" Background="Blue" BorderThickness="1" BorderBrush="Green">
        <Grid>
            <Grid.ColumnDefinitions>
            </Grid.ColumnDefinitions>
            <Button Command="{Binding CloseCommand}" Height="20" Width="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Content="关闭" FontSize="12"/>
            <TextBox Text="{Binding Name}" Height="20" Width="150" TextAlignment="Center" />
            <Button Height="20" Width="150" Command="{Binding ClickCommand}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,246,0,0" Content="点击" FontSize="12"/>

        </Grid>

    </Border>

</Window>
